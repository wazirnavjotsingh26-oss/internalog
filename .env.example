# .env.example — Copy to .env and fill values
# MongoDB Atlas (required, free tier)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/cemetery_db?retryWrites=true&w=majority

# Optional
GOOGLE_PLACES_API_KEY=your_google_places_key_here
ADMIN_PASSWORD=admin123
SECRET_KEY=cemetery-secret-key-change-in-production
FLASK_DEBUG=true
APP_ENV=development

# Frontend (Vite) optional:
# If you host frontend separately, point it at your Render backend.
# VITE_API_BASE=https://intern-alog-012-2.onrender.com

# Required when frontend and backend are on different domains (Vercel + Render):
# Comma-separated allowed frontend origins (no trailing slash)
# FRONTEND_ORIGIN=https://intern-alog-012.vercel.app
# CORS_ALLOWED_ORIGINS=https://intern-alog-012.vercel.app,https://your-preview-domain.vercel.app
# For cross-site admin session cookies:
# SESSION_COOKIE_SAMESITE=None
# SESSION_COOKIE_SECURE=true

# Get MONGO_URI: https://mongodb.com/atlas (5 min setup)

